<Window x:Class="Lab1_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор кредиту та депозиту"
        Height="500" Width="800">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- ===== ДЕПОЗИТ ===== -->
        <StackPanel Grid.Column="0" Margin="10">

            <TextBlock Text="Сума депозиту"/>
            <TextBox Name="DepositAmount"/>

            <TextBlock Text="Річна ставка (%)"/>
            <TextBox Name="DepositRate"/>

            <TextBlock Text="Термін (місяці)"/>
            <TextBox Name="DepositMonths"/>

            <Button Content="Розрахувати депозит"
                    Margin="0,10,0,0"
                    Click="CalculateDeposit_Click"/>

        </StackPanel>

        <!-- ===== КРЕДИТ ===== -->
        <StackPanel Grid.Column="1" Margin="10">

            <TextBlock Text="Сума кредиту"/>
            <TextBox Name="LoanAmount"/>

            <TextBlock Text="Річна ставка (%)"/>
            <TextBox Name="LoanRate"/>

            <TextBlock Text="Термін (місяці)"/>
            <TextBox Name="LoanMonths"/>

            <Button Content="Розрахувати кредит"
                    Margin="0,10,0,0"
                    Click="CalculateLoan_Click"/>

        </StackPanel>

        <!-- ===== РЕЗУЛЬТАТ ===== -->
        <TextBox Name="ResultBox"
                 Grid.ColumnSpan="2"
                 Margin="10,250,10,10"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 IsReadOnly="True"/>

    </Grid>
</Window>
